
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isTeamMember(project) {
      // Check ownerId directly (works for map/scalar).
      // The `uid in team` check is kept for forward-compat but only works if team
      // is restructured as a {uid: true} map. For array-of-objects, ownerId is the
      // reliable signal for leads.
      return request.auth.uid == project.data.ownerId ||
             request.auth.uid in project.data.team;
    }

    // --- Projects Collection ---
    match /projects/{projectId} {
      // **TARGETED CHANGE START**
      // The `list` rule allows collection queries (e.g., getAllProjects).
      // Any signed-in user can list all projects. The filtering for drafts
      // happens in the application code.
      allow list: if isSignedIn();
      
      // The `get` rule secures individual document reads.
      // A user can get a project if it's published OR they are a team member.
      allow get: if resource.data.status == 'published' || isTeamMember(resource);
      // **TARGETED CHANGE END**
      
      allow create: if isSignedIn();
      allow update: if isTeamMember(resource);
      allow delete: if false; // Deletes are disabled for now

      match /tasks/{taskId} {
        allow read: if isSignedIn();
      }

      match /fundingGoals/{goalId} {
        allow read: if isSignedIn();
      }
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // --- Tags Collection ---
    match /tags/{tagId} {
      allow read, write: if isSignedIn();
    }

    // --- Learning Paths Collection ---
    match /learningPaths/{pathId} {
        allow read: if isSignedIn();
        allow write: if false;
    }

    // --- User Progress Collection ---
    match /userLearningProgress/{progressId} {
        allow read, write: if request.auth.uid == resource.data.userId;
    }

    // --- Project Invites Collection ---
    match /projectInvites/{inviteId} {
      // A lead/owner of the project can read any invite for that project.
      // A user can always read their own invite (matched by email).
      allow read: if isSignedIn() && (
        get(/databases/$(database)/documents/projects/$(resource.data.projectId)).data.ownerId == request.auth.uid ||
        request.auth.token.email == resource.data.email
      );
      // Writes are handled exclusively by server-side Admin SDK actions.
      allow write: if false;
    }
  }
}
